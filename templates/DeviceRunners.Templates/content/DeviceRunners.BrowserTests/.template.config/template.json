{
  "$schema": "http://json.schemastore.org/template",
  "author": "DeviceRunners Contributors",
  "classifications": [
    "Blazor",
    "WebAssembly",
    "Test",
    "Xunit"
  ],
  "identity": "DeviceRunners.BrowserTests.CSharp",
  "groupIdentity": "DeviceRunners.BrowserTests",
  "name": "DeviceRunners Browser Tests (Blazor WASM)",
  "description": "A Blazor WebAssembly project for running xUnit tests in the browser using the DeviceRunners visual test runner.",
  "shortName": "devicerunners-browser",
  "defaultName": "BrowserTests",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "DeviceRunners.BrowserTests",
  "preferNameDirectory": true,
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target .NET version for the project.",
      "datatype": "choice",
      "choices": [
        {
          "choice": "net9.0",
          "description": ".NET 9.0"
        },
        {
          "choice": "net10.0",
          "description": ".NET 10.0"
        }
      ],
      "defaultValue": "net9.0",
      "replaces": "DOTNET_TFM"
    }
  },
  "primaryOutputs": [
    {
      "path": "DeviceRunners.BrowserTests.csproj"
    }
  ],
  "postActions": [
    {
      "condition": "",
      "description": "Restore NuGet packages required by this project.",
      "manualInstructions": [
        {
          "text": "Run 'dotnet restore'"
        }
      ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ]
}
