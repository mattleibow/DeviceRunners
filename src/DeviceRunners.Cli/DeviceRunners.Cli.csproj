<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>device-runners</ToolCommandName>
    <PackageId>DeviceRunners.Cli</PackageId>
    <AssemblyName>DeviceRunners.Cli</AssemblyName>
    <!-- PublishTrimmed and EnableTrimAnalyzer are safe in the csproj (only active during publish).
         SelfContained and PublishSingleFile are passed via the command line in PublishCliTools
         to avoid breaking dotnet pack/tool install. -->
    <PublishTrimmed>true</PublishTrimmed>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <!-- Spectre.Console.Cli uses reflection to discover command settings types.
         SuppressTrimAnalysisWarnings keeps the build clean; the TrimmerRootAssembly
         entries below ensure the needed types survive. -->
    <SuppressTrimAnalysisWarnings>true</SuppressTrimAnalysisWarnings>
    <!-- The CLI uses reflection-based JSON and XML serialization for output formatting. -->
    <JsonSerializerIsReflectionEnabledByDefault>true</JsonSerializerIsReflectionEnabledByDefault>
    <RuntimeIdentifiers>osx-arm64;osx-x64;win-x64;win-arm64;linux-x64;linux-arm64</RuntimeIdentifiers>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="DeviceRunners.Cli.Tests" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Spectre.Console.Cli" />
    <PackageReference Include="System.Security.Cryptography.X509Certificates" />
    <PackageReference Include="AndroidSdk" />
    <PackageReference Include="AppleDev" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DeviceRunners.VisualRunners.Core\DeviceRunners.VisualRunners.Core.csproj" />
  </ItemGroup>

  <!-- Root assemblies that rely on reflection and are not trim-safe. -->
  <ItemGroup>
    <TrimmerRootAssembly Include="Spectre.Console.Cli" />
    <TrimmerRootAssembly Include="DeviceRunners.Cli" />
  </ItemGroup>

</Project>