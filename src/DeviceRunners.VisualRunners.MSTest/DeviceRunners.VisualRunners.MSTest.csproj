<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
    <IsPackable>true</IsPackable>
    <!--
      MSTestDiscoverer/MSTestExecutor are the supported in-process embedding entry points for the
      MSTest VSTest adapter. They are marked obsolete (MSTESTOBS) because they will be hidden in
      MSTest v4; we intentionally drive them on the 3.x line, so suppress that diagnostic.
    -->
    <NoWarn>$(NoWarn);MSTESTOBS</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <!-- Provides the VSTest object model (TestCase/TestResult/IFrameworkHandle, etc.) that the
         discoverer/runner and the hand-rolled sink/context/handle are built on. -->
    <PackageReference Include="Microsoft.TestPlatform.ObjectModel" />
    <!--
      The MSTest adapter ships its assemblies as build/content assets rather than as a lib
      reference. We only need it at compile time here (see the <Reference> below); the runtime
      adapter dlls are delivered by the test project that actually contains the MSTest tests (the
      leaf project, e.g. the sample's *.MSTestTests). ExcludeAssets on the build targets prevents
      this library from ALSO carrying/propagating the adapter dlls to consumers, which would
      duplicate them at publish time (NETSDK1152) — the same reason MSTest warns that non-leaf
      "test libraries" should not pull the adapter's build assets. GeneratePathProperty still
      exposes $(PkgMSTest_TestAdapter) for the compile-time reference.
    -->
    <PackageReference Include="MSTest.TestAdapter" GeneratePathProperty="true"
                      ExcludeAssets="build;buildMultitargeting;buildTransitive" />
  </ItemGroup>

  <!--
    MSTestDiscoverer/MSTestExecutor are not exposed as a compile-time reference by the package, so
    reference the adapter dll directly for compilation only (net9.0 asset works on both target
    frameworks). Private=false: the runtime dll is delivered by the package's build targets above,
    so we must not copy a second one (NETSDK1152).
  -->
  <ItemGroup>
    <Reference Include="Microsoft.VisualStudio.TestPlatform.MSTest.TestAdapter">
      <HintPath>$(PkgMSTest_TestAdapter)\buildTransitive\net9.0\Microsoft.VisualStudio.TestPlatform.MSTest.TestAdapter.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DeviceRunners.VisualRunners\DeviceRunners.VisualRunners.csproj" />
  </ItemGroup>

</Project>
