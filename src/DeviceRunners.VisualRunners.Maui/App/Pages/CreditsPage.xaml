<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vr="clr-namespace:DeviceRunners.VisualRunners;assembly=DeviceRunners.VisualRunners"
             xmlns:local="using:DeviceRunners.VisualRunners.Maui"
             x:Class="DeviceRunners.VisualRunners.Maui.Pages.CreditsPage"
             x:DataType="vr:CreditsViewModel"
             Title="Credits">

    <WebView Navigating="OnNavigating">
        <WebView.Source>
            <HtmlWebViewSource Html="{Binding CreditsHtml}" />
        </WebView.Source>
    </WebView>

</ContentPage>