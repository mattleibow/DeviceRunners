<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <NoDefaultExcludes>true</NoDefaultExcludes>
    <PackageId>DeviceRunners.Testing.Targets</PackageId>
    <Description>MSBuild targets that enable `dotnet test` support for .NET device test apps (Android, iOS, macOS, Windows) via the DeviceRunners CLI tool.</Description>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Path to the CLI tool project, relative to this file. -->
    <_CliProjectPath>$(MSBuildThisFileDirectory)..\DeviceRunners.Cli\DeviceRunners.Cli.csproj</_CliProjectPath>
    <_CliToolsDir>$(MSBuildThisFileDirectory)tools\</_CliToolsDir>
  </PropertyGroup>

  <!--
    Publish DeviceRunners.Cli as a framework-dependent binary into tools/.
    The CLI project has SelfContained, PublishSingleFile, and PublishTrimmed
    enabled by default (for standalone use). The NuGet package overrides these
    to produce a framework-dependent publish: any machine running `dotnet test`
    already has the .NET runtime, so we invoke via `dotnet tools/DeviceRunners.Cli.dll`.

    When packing the NuGet package, this target runs automatically before GenerateNuspec.
    To populate the tools/ folder for in-repo use without packing:
      dotnet msbuild DeviceRunners.Testing.Targets.csproj -t:PublishCliTools -c release
  -->
  <Target Name="PublishCliTools" BeforeTargets="GenerateNuspec">
    <Message Importance="high" Text="DeviceRunners.Testing.Targets: publishing CLI tool..." />
    <Exec Command="dotnet publish &quot;$(_CliProjectPath)&quot; -f net9.0 -c $(Configuration) -p:SatelliteResourceLanguages=en -p:SelfContained=false -p:PublishSingleFile=false -p:PublishTrimmed=false -o &quot;$(_CliToolsDir)&quot;" />
  </Target>

  <!--
    Include all files from build/ and tools/ in the NuGet package.
    The tools/<rid>/ binaries are populated by PublishCliTools above.
  -->
  <ItemGroup>
    <None Include="build\**" Pack="true" PackagePath="build\" />
    <None Include="tools\**" Pack="true" PackagePath="tools\" />
  </ItemGroup>

</Project>
