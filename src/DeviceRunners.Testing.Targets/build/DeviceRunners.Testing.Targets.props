<Project>

  <!--
    This project is NOT a Microsoft.Testing.Platform application.
    Device test apps are MAUI apps that communicate over TCP — they don't implement
    the MTP protocol. Setting this prevents MTP's MSBuild targets from blocking our
    custom VSTest override on .NET 10+ SDKs.
  -->
  <PropertyGroup>
    <IsTestingPlatformApplication>false</IsTestingPlatformApplication>
  </PropertyGroup>

  <!--
    Prevent the SDK's Microsoft.TestPlatform.targets from being imported for device
    platforms. The SDK does:
      <VSTestTargets ...>$(MSBuildExtensionsPath)\Microsoft.TestPlatform.targets</VSTestTargets>
      <Import Project="$(VSTestTargets)" Condition="Exists('$(VSTestTargets)')" />
    By pre-setting VSTestTargets to a non-existent path (only when empty), the
    Exists() check fails and the SDK's VSTest target definition is never imported.
    Our custom VSTest target in DeviceRunners.Testing.Targets.targets then becomes
    the only VSTest definition and handles device deployment + test execution.
  -->
  <PropertyGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'
                          Or $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'
                          Or $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'
                          Or $([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">
    <VSTestTargets Condition="'$(VSTestTargets)' == ''">$(MSBuildThisFileDirectory)DeviceRunners.Testing.Targets.VSTest.targets.disabled</VSTestTargets>
    <!--
      Skip the default VSTest build step — our custom VSTest target already has
      DependsOnTargets="Build" so the app is built before tests run.
      This also prevents MTP's _MTPBeforeVSTest from calling BuildProject
      (a target defined only in Microsoft.TestPlatform.targets which we've skipped).
    -->
    <VSTestNoBuild Condition="'$(VSTestNoBuild)' == ''">true</VSTestNoBuild>
  </PropertyGroup>

  <!--
    Default properties injected before the project builds.
    Users can override any of these in their own .csproj.
  -->
  <PropertyGroup>
    <!-- TCP port the CLI tool listens on (and the app connects to). -->
    <DeviceRunnersPort Condition="'$(DeviceRunnersPort)' == ''">16384</DeviceRunnersPort>

    <!-- How long (seconds) the CLI waits for the first TCP connection from the device. -->
    <DeviceRunnersConnectionTimeout Condition="'$(DeviceRunnersConnectionTimeout)' == ''">120</DeviceRunnersConnectionTimeout>

    <!-- How long (seconds) the CLI waits for more data after the last received packet. -->
    <DeviceRunnersDataTimeout Condition="'$(DeviceRunnersDataTimeout)' == ''">30</DeviceRunnersDataTimeout>

    <!--
      Target device/emulator to use. Leave empty to use the booted/default device.
      For iOS: the simulator UDID (e.g. from `xcrun simctl list` or dotnet apple simulator create).
      For Android: the device serial number (e.g. emulator-5554).
    -->
    <DeviceRunnersDevice Condition="'$(DeviceRunnersDevice)' == ''" />

    <!-- Where TRX / raw event files are written. Defaults to $(ArtifactsPath)\test-results when
         UseArtifactsOutput=true, otherwise to $(MSBuildProjectDirectory)\test-results. -->
    <TestResultsDirectory Condition="'$(TestResultsDirectory)' == '' And '$(ArtifactsPath)' != ''">$([MSBuild]::EnsureTrailingSlash('$(ArtifactsPath)'))test-results\</TestResultsDirectory>
    <TestResultsDirectory Condition="'$(TestResultsDirectory)' == ''">$(MSBuildProjectDirectory)\test-results\</TestResultsDirectory>
  </PropertyGroup>

  <!--
    Android: EmbedAssembliesIntoApk is NOT set here. The dotnet test targets
    use the platform's Install target (which handles Fast Deployment) instead
    of having the CLI do adb install. See the .targets file for details.
  -->

</Project>
