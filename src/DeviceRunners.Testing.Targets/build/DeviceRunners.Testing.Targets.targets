<Project>

  <!--
    CLI tool resolution.

    The NuGet package ships self-contained, single-file binaries per RID in
    tools/<rid>/. The targets detect the host OS and select the right binary.

    Override by setting $(DeviceRunnersBin) in your project file:
      <PropertyGroup>
        <DeviceRunnersBin>device-runners</DeviceRunnersBin>
      </PropertyGroup>
  -->
  <PropertyGroup>
    <_DeviceRunnersToolsDir>$(MSBuildThisFileDirectory)..\tools\</_DeviceRunnersToolsDir>
    <_DeviceRunnersArch>$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture.ToString().ToLowerInvariant())</_DeviceRunnersArch>
    <_DeviceRunnersArch Condition="'$(_DeviceRunnersArch)' == 'x64'">x64</_DeviceRunnersArch>
    <_DeviceRunnersArch Condition="'$(_DeviceRunnersArch)' == 'arm64'">arm64</_DeviceRunnersArch>
    <_DeviceRunnersRid Condition="$([MSBuild]::IsOSPlatform('osx'))">osx-$(_DeviceRunnersArch)</_DeviceRunnersRid>
    <_DeviceRunnersRid Condition="$([MSBuild]::IsOSPlatform('windows'))">win-$(_DeviceRunnersArch)</_DeviceRunnersRid>
    <_DeviceRunnersRid Condition="$([MSBuild]::IsOSPlatform('linux'))">linux-$(_DeviceRunnersArch)</_DeviceRunnersRid>
    <_DeviceRunnersExePath Condition="$([MSBuild]::IsOSPlatform('windows'))">$(_DeviceRunnersToolsDir)$(_DeviceRunnersRid)\DeviceRunners.Cli.exe</_DeviceRunnersExePath>
    <_DeviceRunnersExePath Condition="!$([MSBuild]::IsOSPlatform('windows'))">$(_DeviceRunnersToolsDir)$(_DeviceRunnersRid)\DeviceRunners.Cli</_DeviceRunnersExePath>
    <_DeviceRunnersCommand Condition="'$(DeviceRunnersBin)' != ''">$(DeviceRunnersBin)</_DeviceRunnersCommand>
    <_DeviceRunnersCommand Condition="'$(DeviceRunnersBin)' == ''">$(_DeviceRunnersExePath)</_DeviceRunnersCommand>
  </PropertyGroup>

  <!--
    Compute the target platform once so all targets and conditions can use
    $(_DeviceRunnersPlatform) instead of repeating the property function call.
    $(_DeviceRunnersIsSupportedPlatform) drives the VSTest entry-point condition.
  -->
  <PropertyGroup>
    <_DeviceRunnersPlatform>$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)'))</_DeviceRunnersPlatform>
    <!--
      Blazor WebAssembly projects use plain net9.0/net10.0 (no -browser TFM), so
      GetTargetPlatformIdentifier returns empty. Detect them via the SDK property
      UsingMicrosoftNETSdkBlazorWebAssembly which the BlazorWebAssembly SDK sets.
    -->
    <_DeviceRunnersPlatform Condition="'$(_DeviceRunnersPlatform)' == '' And '$(UsingMicrosoftNETSdkBlazorWebAssembly)' == 'true'">browser</_DeviceRunnersPlatform>
    <_DeviceRunnersIsSupportedPlatform Condition="'$(_DeviceRunnersPlatform)' == 'android'
                                               Or '$(_DeviceRunnersPlatform)' == 'ios'
                                               Or '$(_DeviceRunnersPlatform)' == 'maccatalyst'
                                               Or '$(_DeviceRunnersPlatform)' == 'windows'
                                               Or '$(_DeviceRunnersPlatform)' == 'browser'">true</_DeviceRunnersIsSupportedPlatform>
  </PropertyGroup>

  <!-- =[ Entry point ]= -->

  <!--
    VSTest - invoked by "dotnet test".

    Replaces the default VSTest behaviour for device platforms:
      1. _DeviceRunnersMarkTestRun - set DeviceRunnersTestRun=true for env injection
      2. Build                      - compile the app (APK / .app / .exe)
      3. _DeviceRunnersRunTests     - prepare args, exec CLI, report results
  -->
  <Target Name="VSTest"
          DependsOnTargets="_DeviceRunnersMarkTestRun;Build;_DeviceRunnersRunTests"
          Condition="'$(_DeviceRunnersIsSupportedPlatform)' == 'true'" />

  <!--
    Marks this build as a test run so Android env var injection is gated
    on dotnet test only. Runs before Build so the property is visible to
    _GenerateEnvironmentFiles in the Android inner build.
  -->
  <Target Name="_DeviceRunnersMarkTestRun">
    <PropertyGroup>
      <DeviceRunnersTestRun>true</DeviceRunnersTestRun>
    </PropertyGroup>
  </Target>

  <!-- =[ Orchestrator ]= -->

  <!--
    Chains the three test-execution phases in order.
    Each phase is a separate target so MSBuild tracks them individually and
    an error in one phase halts execution before the next phase starts.
  -->
  <Target Name="_DeviceRunnersRunTests"
          DependsOnTargets="_DeviceRunnersPrepareArgs;_DeviceRunnersExecTests;_DeviceRunnersReportResults" />

  <!-- =[ Phase 1: Prepare arguments ]= -->

  <!--
    Chains common arg setup then the single platform-specific arg target whose
    Condition matches. All four platform targets are listed; only one runs.
    Properties set here flow into _DeviceRunnersExecTests and _DeviceRunnersReportResults.
  -->
  <Target Name="_DeviceRunnersPrepareArgs"
          DependsOnTargets="_DeviceRunnersCommonArgs;_DeviceRunnersAndroidArgs;_DeviceRunnersiOSArgs;_DeviceRunnersMacOSArgs;_DeviceRunnersWindowsArgs;_DeviceRunnersWasmArgs" />

  <!--
    Shared setup: TRX output path, results directory, optional device flag,
    and the common CLI flags shared by all platforms.
  -->
  <Target Name="_DeviceRunnersCommonArgs">
    <PropertyGroup>
      <!--
        Use VSTestResultsDirectory (set by "dotnet test ‑‑results-directory") when
        available; otherwise fall back to the project-level default.
      -->
      <_DeviceRunnersResultsDir Condition="'$(VSTestResultsDirectory)' != ''">$(VSTestResultsDirectory)</_DeviceRunnersResultsDir>
      <_DeviceRunnersResultsDir Condition="'$(_DeviceRunnersResultsDir)' == ''">$([System.IO.Path]::GetDirectoryName('$(TestResultsDirectory)test-results.trx'))</_DeviceRunnersResultsDir>

      <!--
        Expected TRX path for the report phase. The CLI writes TRX to the
        results directory with the filename from the logger arg. We use a
        default name so the report target knows where to look.
      -->
      <_DeviceRunnersTrxFile>$([System.IO.Path]::Combine('$(_DeviceRunnersResultsDir)', 'test-results.trx'))</_DeviceRunnersTrxFile>

      <!-- Optional device flag; expands to empty string when DeviceRunnersDevice is unset. -->
      <_DeviceRunnersDeviceArg />
      <_DeviceRunnersDeviceArg Condition="'$(DeviceRunnersDevice)' != ''"> --device &quot;$(DeviceRunnersDevice)&quot;</_DeviceRunnersDeviceArg>

      <!--
        Forward the logger setting from "dotnet test ‑‑logger" ($(VSTestLogger))
        when present. When no logger is specified, match "dotnet test" default
        behaviour and omit the flag entirely (no TRX produced).
      -->
      <_DeviceRunnersLoggerArg />
      <_DeviceRunnersLoggerArg Condition="'$(VSTestLogger)' != ''"> --logger &quot;$(VSTestLogger)&quot;</_DeviceRunnersLoggerArg>

      <!-- Flags shared by every platform sub-command. -->
      <_DeviceRunnersCommonCliArgs>--results-directory &quot;$(_DeviceRunnersResultsDir)&quot; --port $(DeviceRunnersPort) --connection-timeout $(DeviceRunnersConnectionTimeout) --data-timeout $(DeviceRunnersDataTimeout)$(_DeviceRunnersLoggerArg)</_DeviceRunnersCommonCliArgs>
    </PropertyGroup>
    <MakeDir Directories="$(_DeviceRunnersResultsDir)" />
  </Target>

  <!-- =[ Android args ]= -->

  <!--
    Android uses the platform's Install target to deploy the APK (which handles
    both regular install and Fast Deployment). The CLI then launches the app
    by package name (no adb install needed) and listens for TCP results.
  -->
  <Target Name="_DeviceRunnersAndroidArgs"
          Condition="'$(_DeviceRunnersPlatform)' == 'android'"
          DependsOnTargets="Install">
    <PropertyGroup>
      <_DeviceRunnersCliArgs>android test --package &quot;$(ApplicationId)&quot;$(_DeviceRunnersDeviceArg) $(_DeviceRunnersCommonCliArgs)</_DeviceRunnersCliArgs>
    </PropertyGroup>
    <Message Importance="high" Text="DeviceRunners: running Android tests for $(ApplicationId)" />
  </Target>

  <!-- =[ iOS args ]= -->

  <!--
    MSBuild's Include glob does not reliably match directories by name on macOS
    (*.app/ fails), so use Directory.GetDirectories to locate the .app bundle.
  -->
  <Target Name="_DeviceRunnersiOSArgs"
          Condition="'$(_DeviceRunnersPlatform)' == 'ios'">
    <PropertyGroup>
      <_DeviceRunnersAppPath>$([System.IO.Directory]::GetDirectories('$(OutputPath)', '$(AssemblyName).app'))</_DeviceRunnersAppPath>
      <_DeviceRunnersAppPath>$(_DeviceRunnersAppPath.TrimEnd('\').TrimEnd('/'))</_DeviceRunnersAppPath>
    </PropertyGroup>
    <Error Text="No .app bundle found in '$(OutputPath)'. Make sure the project builds successfully."
           Condition="'$(_DeviceRunnersAppPath)' == ''" />
    <PropertyGroup>
      <_DeviceRunnersCliArgs>ios test --app &quot;$(_DeviceRunnersAppPath)&quot;$(_DeviceRunnersDeviceArg) $(_DeviceRunnersCommonCliArgs)</_DeviceRunnersCliArgs>
    </PropertyGroup>
    <Message Importance="high" Text="DeviceRunners: running iOS tests from $(_DeviceRunnersAppPath)" />
  </Target>

  <!-- =[ macOS Catalyst args ]= -->

  <Target Name="_DeviceRunnersMacOSArgs"
          Condition="'$(_DeviceRunnersPlatform)' == 'maccatalyst'">
    <PropertyGroup>
      <_DeviceRunnersAppPath>$([System.IO.Directory]::GetDirectories('$(OutputPath)', '$(AssemblyName).app'))</_DeviceRunnersAppPath>
      <_DeviceRunnersAppPath>$(_DeviceRunnersAppPath.TrimEnd('\').TrimEnd('/'))</_DeviceRunnersAppPath>
    </PropertyGroup>
    <Error Text="No .app bundle found in '$(OutputPath)'. Make sure the project builds successfully."
           Condition="'$(_DeviceRunnersAppPath)' == ''" />
    <PropertyGroup>
      <!-- macOS always runs on the local machine; the device flag is not applicable. -->
      <_DeviceRunnersCliArgs>macos test --app &quot;$(_DeviceRunnersAppPath)&quot; $(_DeviceRunnersCommonCliArgs)</_DeviceRunnersCliArgs>
    </PropertyGroup>
    <Message Importance="high" Text="DeviceRunners: running macOS Catalyst tests from $(_DeviceRunnersAppPath)" />
  </Target>

  <!-- =[ Windows args ]= -->

  <!--
    Detects the Windows build output and assembles CLI arguments:
    - Unpackaged (.exe): WindowsPackageType=None produces a plain executable
    - Loose MSIX layout: default packaging produces a folder with AppxManifest.xml
      which the CLI registers via winapp.exe (no dotnet publish needed)
  -->
  <Target Name="_DeviceRunnersWindowsArgs"
          Condition="'$(_DeviceRunnersPlatform)' == 'windows'">
    <PropertyGroup>
      <_DeviceRunnersWindowsExe>$(OutputPath)$(AssemblyName).exe</_DeviceRunnersWindowsExe>
      <_DeviceRunnersWindowsManifest>$(OutputPath)AppxManifest.xml</_DeviceRunnersWindowsManifest>
    </PropertyGroup>

    <!-- Unpackaged: use the .exe directly -->
    <PropertyGroup Condition="Exists('$(_DeviceRunnersWindowsExe)') And !Exists('$(_DeviceRunnersWindowsManifest)')">
      <_DeviceRunnersCliArgs>windows test --app &quot;$(_DeviceRunnersWindowsExe)&quot; $(_DeviceRunnersCommonCliArgs)</_DeviceRunnersCliArgs>
      <_DeviceRunnersWindowsApp>$(_DeviceRunnersWindowsExe)</_DeviceRunnersWindowsApp>
    </PropertyGroup>

    <!-- Loose MSIX layout: point CLI at the output folder (it finds AppxManifest.xml) -->
    <PropertyGroup Condition="Exists('$(_DeviceRunnersWindowsManifest)')">
      <_DeviceRunnersCliArgs>windows test --app &quot;$(OutputPath).&quot; $(_DeviceRunnersCommonCliArgs)</_DeviceRunnersCliArgs>
      <_DeviceRunnersWindowsApp>$(OutputPath)</_DeviceRunnersWindowsApp>
    </PropertyGroup>

    <Error Text="No Windows app found in '$(OutputPath)'. Expected either an .exe (WindowsPackageType=None) or a folder with AppxManifest.xml."
           Condition="'$(_DeviceRunnersWindowsApp)' == ''" />
    <Message Importance="high" Text="DeviceRunners: running Windows tests from $(_DeviceRunnersWindowsApp)" />
  </Target>

  <!-- =[ WASM (browser) args ]= -->

  <!--
    For browser WASM projects, "dotnet test" publishes the app then invokes
    the CLI's "wasm test" command which starts a web server, launches a
    headless browser, captures console output (NDJSON), and produces TRX.
    
    The publish output is at $(PublishDir) which contains the wwwroot/ with
    index.html, the .wasm/.dll files, and the Blazor framework files.
  -->
  <Target Name="_DeviceRunnersWasmArgs"
          Condition="'$(_DeviceRunnersPlatform)' == 'browser'"
          DependsOnTargets="Publish">
    <PropertyGroup>
      <!-- Look for wwwroot inside publish output; if not found, use publish dir directly -->
      <_DeviceRunnersWasmDir Condition="Exists('$(PublishDir)wwwroot')">$(PublishDir)wwwroot</_DeviceRunnersWasmDir>
      <_DeviceRunnersWasmDir Condition="'$(_DeviceRunnersWasmDir)' == ''">$(PublishDir)</_DeviceRunnersWasmDir>
    </PropertyGroup>
    <Error Text="Published WASM output not found at '$(PublishDir)'. Make sure the project publishes successfully."
           Condition="!Exists('$(_DeviceRunnersWasmDir)')" />
    <PropertyGroup>
      <!-- WASM uses different CLI flags: no port/TCP, instead uses browser console capture -->
      <_DeviceRunnersCliArgs>wasm test --app &quot;$(_DeviceRunnersWasmDir)&quot; --results-directory &quot;$(_DeviceRunnersResultsDir)&quot;$(_DeviceRunnersLoggerArg) --timeout $(DeviceRunnersWasmTimeout)</_DeviceRunnersCliArgs>
    </PropertyGroup>
    <Message Importance="high" Text="DeviceRunners: running WASM browser tests from $(_DeviceRunnersWasmDir)" />
  </Target>


  <!-- =[ Phase 2: Execute tests ]= -->

  <!--
    Single Exec that runs the CLI with the fully assembled $(_DeviceRunnersCliArgs).
    IgnoreExitCode="true" prevents MSBuild from emitting a raw MSB3073 error;
    the exit code is forwarded to _DeviceRunnersReportResults for clean reporting.
  -->
  <Target Name="_DeviceRunnersExecTests">
    <Exec Command="&quot;$(_DeviceRunnersCommand)&quot; $(_DeviceRunnersCliArgs)"
          IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="_DeviceRunnersExitCode" />
    </Exec>
  </Target>

  <!-- =[ Phase 3: Report results ]= -->

  <!--
    Parse the TRX written by the CLI and emit output matching the standard
    dotnet test format so that tooling that parses dotnet test output works:

      Test summary: total: 44, failed: 5, succeeded: 36, skipped: 3, duration: 28.7s
      See TRX for details: /path/to/test-results.trx

    The TRX uses the http://microsoft.com/schemas/VisualStudio/TeamTest/2010
    namespace, so XmlPeek queries must be namespace-qualified.

    Skipped count: Counters/@notExecuted stays 0 for intentional xunit/nunit
    skips by design (that counter is for infrastructure failures). We count
    UnitTestResult[@outcome='NotExecuted'] elements directly instead.
    See TrxResultChannelFormatter.cs for details.

    Duration is derived from Times/@start and Times/@finish in the TRX.

    Fallback: if the CLI crashed before writing the TRX, emit a plain error
    with the exit code so the cause is still visible.
  -->
  <Target Name="_DeviceRunnersReportResults">

    <PropertyGroup>
      <_DeviceRunnersTrxExists Condition="Exists('$(_DeviceRunnersTrxFile)')">true</_DeviceRunnersTrxExists>
      <_DeviceRunnersTrxExists Condition="'$(_DeviceRunnersTrxExists)' == ''">false</_DeviceRunnersTrxExists>
      <_DeviceRunnersNs>&lt;Namespace Prefix='t' Uri='http://microsoft.com/schemas/VisualStudio/TeamTest/2010'/&gt;</_DeviceRunnersNs>
    </PropertyGroup>

    <!-- Read scalar counters as properties (single-value XPath attributes). -->
    <XmlPeek XmlInputPath="$(_DeviceRunnersTrxFile)" Namespaces="$(_DeviceRunnersNs)"
             Query="//t:Counters/@total"
             Condition="'$(_DeviceRunnersTrxExists)' == 'true'">
      <Output TaskParameter="Result" PropertyName="_TrxTotal" />
    </XmlPeek>
    <XmlPeek XmlInputPath="$(_DeviceRunnersTrxFile)" Namespaces="$(_DeviceRunnersNs)"
             Query="//t:Counters/@passed"
             Condition="'$(_DeviceRunnersTrxExists)' == 'true'">
      <Output TaskParameter="Result" PropertyName="_TrxPassed" />
    </XmlPeek>
    <XmlPeek XmlInputPath="$(_DeviceRunnersTrxFile)" Namespaces="$(_DeviceRunnersNs)"
             Query="//t:Counters/@failed"
             Condition="'$(_DeviceRunnersTrxExists)' == 'true'">
      <Output TaskParameter="Result" PropertyName="_TrxFailed" />
    </XmlPeek>

    <!-- Read run start/finish timestamps to compute wall-clock duration. -->
    <XmlPeek XmlInputPath="$(_DeviceRunnersTrxFile)" Namespaces="$(_DeviceRunnersNs)"
             Query="//t:Times/@start"
             Condition="'$(_DeviceRunnersTrxExists)' == 'true'">
      <Output TaskParameter="Result" PropertyName="_TrxStart" />
    </XmlPeek>
    <XmlPeek XmlInputPath="$(_DeviceRunnersTrxFile)" Namespaces="$(_DeviceRunnersNs)"
             Query="//t:Times/@finish"
             Condition="'$(_DeviceRunnersTrxExists)' == 'true'">
      <Output TaskParameter="Result" PropertyName="_TrxFinish" />
    </XmlPeek>

    <!--
      Count skipped tests by counting UnitTestResult elements with outcome="NotExecuted".
      Counters/@notExecuted stays 0 for intentional skips by design.
    -->
    <XmlPeek XmlInputPath="$(_DeviceRunnersTrxFile)" Namespaces="$(_DeviceRunnersNs)"
             Query="//t:UnitTestResult/@testId[../@outcome='NotExecuted']"
             Condition="'$(_DeviceRunnersTrxExists)' == 'true'">
      <Output TaskParameter="Result" ItemName="_TrxSkipped" />
    </XmlPeek>

    <!-- Compute duration in seconds from start/finish timestamps. -->
    <PropertyGroup Condition="'$(_DeviceRunnersTrxExists)' == 'true' And '$(_TrxStart)' != '' And '$(_TrxFinish)' != ''">
      <_TrxDuration>$([System.Math]::Round($([System.DateTime]::Parse('$(_TrxFinish)').Subtract($([System.DateTime]::Parse('$(_TrxStart)'))).TotalSeconds), 1))</_TrxDuration>
    </PropertyGroup>
    <PropertyGroup>
      <_TrxDuration Condition="'$(_TrxDuration)' == ''">0</_TrxDuration>
    </PropertyGroup>

    <!--
      Emit the standard dotnet test output format.
      Note: the dotnet CLI terminal logger (enabled by default in .NET 8+) filters
      Message tasks regardless of Importance. These lines are visible when running
      with "tl:off" or "verbosity normal". The error TESTERROR line below always
      surfaces the summary for the default terminal logger case.
    -->
    <Message Importance="high"
             Text="Results File: $(_DeviceRunnersTrxFile)"
             Condition="'$(_DeviceRunnersTrxExists)' == 'true'" />
    <Message Importance="high"
             Text="Test summary: total: $(_TrxTotal), failed: $(_TrxFailed), succeeded: $(_TrxPassed), skipped: @(_TrxSkipped->Count()), duration: $(_TrxDuration)s"
             Condition="'$(_DeviceRunnersTrxExists)' == 'true'" />

    <!--
      Signal MSBuild failure.
      CLI exit codes: 0 = success, 1 = test failures, 2 = app crashed.
    -->
    <Error Code="TESTERROR"
           Text="Test summary: total: $(_TrxTotal), failed: $(_TrxFailed), succeeded: $(_TrxPassed), skipped: @(_TrxSkipped->Count()), duration: $(_TrxDuration)s (incomplete: app crashed)"
           Condition="'$(_DeviceRunnersTrxExists)' == 'true' And '$(_DeviceRunnersExitCode)' == '2'" />

    <Error Code="TESTERROR"
           Text="Test summary: total: $(_TrxTotal), failed: $(_TrxFailed), succeeded: $(_TrxPassed), skipped: @(_TrxSkipped->Count()), duration: $(_TrxDuration)s"
           Condition="'$(_DeviceRunnersTrxExists)' == 'true' And '$(_DeviceRunnersExitCode)' == '1'" />

    <Error Code="TESTERROR"
           Text="The application crashed before producing any test results (exit code 2). Check the device log for details."
           Condition="'$(_DeviceRunnersTrxExists)' == 'false' And '$(_DeviceRunnersExitCode)' == '2'" />

    <Error Code="TESTERROR" Text="DeviceRunners CLI exited with code $(_DeviceRunnersExitCode) and no TRX was written. Check the output above for details."
           Condition="'$(_DeviceRunnersTrxExists)' == 'false' And '$(_DeviceRunnersExitCode)' != '0' And '$(_DeviceRunnersExitCode)' != '2'" />

  </Target>

  <!-- =[ Android env vars baked into APK at build ]= -->

  <!--
    Injects DeviceRunners configuration into the APK via the Android SDK's
    _GenerateEnvironmentFiles mechanism. The Mono runtime reads the resulting
    KEY=VALUE file (__environment__.txt) at startup.

    Only injects when dotnet test is running (DeviceRunnersTestRun=true).
    When the app is built normally (dotnet build / IDE), the env vars are
    NOT injected, so the app behaves as a normal visual runner.

    Pass -p:DeviceRunnersTestRun=true to inject for manual CLI testing, or
    let the VSTest target set it automatically.

    10.0.2.2 is the Android emulator's gateway address to reach the host machine.
    localhost covers physical devices when port-forwarded or on the same network.
  -->
  <Target Name="_DeviceRunnersAndroidEnvironment"
          BeforeTargets="_GenerateEnvironmentFiles"
          Condition="'$(_DeviceRunnersPlatform)' == 'android' And '$(DeviceRunnersTestRun)' == 'true'">
    <ItemGroup>
      <_GeneratedAndroidEnvironment Include="DEVICE_RUNNERS_AUTORUN=1" />
      <_GeneratedAndroidEnvironment Include="DEVICE_RUNNERS_PORT=$(DeviceRunnersPort)" />
      <_GeneratedAndroidEnvironment Include="DEVICE_RUNNERS_HOST_NAMES=localhost%3B10.0.2.2" />
    </ItemGroup>
  </Target>

</Project>
