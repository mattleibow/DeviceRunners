<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
    <IsPackable>true</IsPackable>
    <!--
      MSTestDiscoverer/MSTestExecutor are the supported in-process embedding entry points for the
      MSTest VSTest adapter. They are marked obsolete (MSTESTOBS) because they will be hidden in
      MSTest v4; we intentionally drive them on the 3.x line, so suppress that diagnostic.
    -->
    <NoWarn>$(NoWarn);MSTESTOBS</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <!-- Provides the VSTest object model (TestCase/TestResult/IFrameworkHandle, etc.) that the
         discoverer/runner and the hand-rolled sink/context/handle are built on. -->
    <PackageReference Include="Microsoft.TestPlatform.ObjectModel" />
    <!--
      The MSTest adapter ships its assemblies as build/content assets rather than as lib
      references. ExcludeAssets on the build targets suppresses that content-copy mechanism: it
      places the dlls beside the app on the filesystem, which loads on Windows but NOT on Android/
      iOS, where assemblies are loaded from the app's assembly store and must be part of the
      runtime closure (deps.json). Instead we pull the two MSTest-specific dlls in as real
      references below so they become closure assemblies on every platform. GeneratePathProperty
      exposes $(PkgMSTest_TestAdapter) for those reference HintPaths.
    -->
    <PackageReference Include="MSTest.TestAdapter" GeneratePathProperty="true"
                      ExcludeAssets="build;buildMultitargeting;buildTransitive" />
  </ItemGroup>

  <!--
    MSTestDiscoverer/MSTestExecutor (and the platform services the adapter loads at runtime) are not
    exposed as lib references by the package, so reference the two MSTest-specific dlls directly from
    the restored package (the net9.0 assets work on both target frameworks). Private=true makes them
    copy-local so they enter this library's runtime closure and are deployed as real assemblies to
    every platform's app — this is the single owner of these dlls. The rest of the test-platform
    stack (ObjectModel, CoreUtilities, PlatformAbstractions, AdapterUtilities) comes from the normal
    Microsoft.TestPlatform.ObjectModel package reference above.
  -->
  <ItemGroup>
    <Reference Include="Microsoft.VisualStudio.TestPlatform.MSTest.TestAdapter">
      <HintPath>$(PkgMSTest_TestAdapter)\buildTransitive\net9.0\Microsoft.VisualStudio.TestPlatform.MSTest.TestAdapter.dll</HintPath>
      <Private>true</Private>
    </Reference>
    <Reference Include="Microsoft.VisualStudio.TestPlatform.MSTestAdapter.PlatformServices">
      <HintPath>$(PkgMSTest_TestAdapter)\buildTransitive\net9.0\Microsoft.VisualStudio.TestPlatform.MSTestAdapter.PlatformServices.dll</HintPath>
      <Private>true</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DeviceRunners.VisualRunners\DeviceRunners.VisualRunners.csproj" />
  </ItemGroup>

</Project>
